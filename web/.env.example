# --- Admin panel ---
# Password to sign in at /admin (change this for production!)
ADMIN_PASSWORD=starpass
# Secret used to sign the admin session cookie (any long random string)
ADMIN_SECRET=change-me-to-a-long-random-string

# --- Photo storage in production (Vercel) ---
# Auto-added by Vercel when you connect a Blob store to the project.
# When present, photos & content are stored in Vercel Blob instead of the
# local filesystem. Leave unset for local development.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# --- Contact form delivery (optional) ---
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=987654321
