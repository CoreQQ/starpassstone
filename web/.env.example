# --- Site ---
# Public base URL, used for canonical links, sitemap, robots and Open Graph.
NEXT_PUBLIC_SITE_URL=https://starpassstone.net

# --- Admin panel ---
# Password to sign in at /admin (change this for production!)
ADMIN_PASSWORD=starpass
# Secret used to sign the admin session cookie (any long random string)
ADMIN_SECRET=change-me-to-a-long-random-string
# Secret used to sign user-account JWTs (any long random string)
JWT_SECRET=change-me-to-another-long-random-string

# --- Database (optional) ---
# When set, the app uses PostgreSQL via Prisma for content, analytics, logs and
# users. Run `npm run db:migrate` (prisma migrate deploy) after setting it.
# Leave unset to use the zero-infrastructure JSON/Blob store instead.
# DATABASE_URL=postgresql://user:pass@host:5432/starpass?schema=public

# --- Photo & analytics storage in production (Vercel) ---
# Auto-added by Vercel when you connect a Blob store to the project.
# When present, content, uploads, visits and logs are stored in Vercel Blob
# instead of the local filesystem. Leave unset for local development.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# --- Telegram notifications (optional) ---
# When both are set, the bot delivers contact leads AND sends alerts for every
# site visit, admin login, upload and server error. Leave unset to run in demo
# mode (nothing is sent; the site still works).
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=987654321

# --- Optional NestJS lead backend ---
# If set, contact leads are forwarded here instead of straight to Telegram.
# NEST_API_URL=http://localhost:4000/api
