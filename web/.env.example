# --- Admin panel ---
# Password to sign in at /admin (change this for production!)
ADMIN_PASSWORD=starpass
# Secret used to sign the admin session cookie (set any long random string)
ADMIN_SECRET=change-me-to-a-long-random-string

# --- Contact form delivery (optional) ---
# Forward leads to the NestJS backend:
# NEST_API_URL=http://localhost:4000/api
# Or deliver leads straight to Telegram (mirrors the original site):
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=987654321
